{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],            // 👈 Ensure isme 'dom' na ho, backend ke liye 'ES2022' ya 'ESNext' sahi hai
    "skipLibCheck": true,         // 👈 Yeh sabse important hai, yeh external library ke internal mismatch types ko ignore karega
    "strict": true,
    "noImplicitAny": false,       // 👈 Isko temporarily 'false' kar do taaki 'tx', 'acc', 'sum' wale (TS7006) errors turant bypass ho jayein
    "esModuleInterop": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "prisma"]
}
